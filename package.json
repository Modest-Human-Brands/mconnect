{
  "name": "mconnect",
  "version": "0.2.5",
  "description": "A client outreach and communication hub for managing message/mail/popup templates, tracking campaigns, and monitoring client in-reach and out-reach activity",
  "author": "Shirsendu Bairagi <shirsendu2001@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Modest-Human-Brands/mconnect.git"
  },
  "type": "module",
  "private": true,
  "engines": {
    "node": "^22.11.0 || ^24.14.0",
    "pnpm": "^9.15.0 || ^10.2.0",
    "bun": "^1.2.9"
  },
  "packageManager": "bun@1.3.12",
  "scripts": {
    "prepare": "husky || true",
    "dev": "sh -c \"iii-cli start -c iii-config.yaml & iii-cli console --enable-flow\"",
    "detect": "gitleaks git --verbose",
    "lint": "eslint . --fix",
    "format": "prettier . --write",
    "build": "motia build --external @maizzle/framework,@tailwindcss/oxide,oxfmt",
    "start": "motia start",
    "clean": "rm -rf .motia dist",
    "mazzile:dev": "maizzle serve",
    "mazzile:build": "maizzle build",
    "docker:build": "docker build --build-arg VERSION=dev --build-arg BUILD_TIME=now -t motiatemplate:dev .",
    "docker:start": "docker run --detach --name mmedia-dev --env-file .env.prod -p 3500:3000 motiatemplate:dev"
  },
  "dependencies": {
    "@maizzle/framework": "^6.0.0-rc.7",
    "@maizzle/tailwindcss": "^1.4.2",
    "motia": "^1.0.4-rc.1",
    "ofetch": "^1.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@dotenvx/dotenvx": "^1.61.0",
    "@types/bun": "^1.3.12",
    "eslint": "^10.2.0",
    "eslint-config-unjs": "^0.6.2",
    "husky": "^9.1.7",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2"
  }
}
